# Copy this file to .env and fill in your own keys. Never commit the real .env file.

# --- Twilio (telephony) --- https://console.twilio.com
# Account SID / Auth Token: found on your Twilio console dashboard.
# Phone number: a Twilio number you've purchased that supports voice calls.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Deepgram (speech-to-text) --- https://console.deepgram.com
# Free tier available.
DEEPGRAM_API_KEY=

# --- Sarvam AI (text-to-speech) --- https://sarvam.ai
# Built for Hindi/English + other Indian languages. Check their free-tier
# terms at signup. SARVAM_VOICE options (bulbul:v2): anushka, manisha, vidya,
# arya (female), abhilash, karun, hitesh (male).
SARVAM_API_KEY=
SARVAM_VOICE=anushka

# --- Groq (LLM inference) --- https://console.groq.com
# Genuinely free, ongoing tier (rate-limited, not credit-limited).
GROQ_API_KEY=

# --- Dashboard auth ---
# HTTP Basic auth protecting the web dashboard and /start (the endpoint that
# places real, billed phone calls) - required, since anyone with this
# password could trigger calls on your Twilio account. send_reminders.py
# reads these too, to authenticate its own requests to /start.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# --- Contact form (landing page) --- https://resend.com
# Free tier: 100 emails/day, no domain verification needed to send from
# onboarding@resend.dev. Sign up, create an API key, and set where
# submissions should land.
RESEND_API_KEY=
CONTACT_EMAIL_TO=

# --- App configuration ---
HOSPITAL_NAME=City Care Hospital
PORT=7860

# Public base URL of this server, used by send_reminders.py to trigger calls.
# When testing locally, this is your ngrok https URL (see README), e.g.:
# SERVER_BASE_URL=https://abc123.ngrok-free.app
SERVER_BASE_URL=http://localhost:7860
